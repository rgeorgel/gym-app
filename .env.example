# Database
POSTGRES_DB=gymapp
POSTGRES_USER=gymapp
POSTGRES_PASSWORD=gymapp123

# JWT — CHANGE IN PRODUCTION (minimum 32 characters)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN_PLEASE

# App environment
ASPNETCORE_ENVIRONMENT=Development

# Port mapping (host port for the web frontend)
WEB_PORT=8095

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost

# Email provider: SendGrid | Resend (default: SendGrid)
EMAIL_PROVIDER=SendGrid

# SendGrid (use if EMAIL_PROVIDER=SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@seudominio.com
SENDGRID_FROM_NAME=Gym App

# Resend (use if EMAIL_PROVIDER=Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@seudominio.com
RESEND_FROM_NAME=Gym App

# AbacatePay — subscription billing (https://abacatepay.com)
ABACATEPAY_API_KEY=
ABACATEPAY_PRICE_CENTS=4900

# Efí Bank — PIX payments (https://sejaefi.com.br)
# Leave empty to disable payments
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERTIFICATE_BASE64=
EFI_CERTIFICATE_PASSWORD=
EFI_PIX_KEY=
EFI_PLATFORM_PAYEE_CODE=
EFI_PLATFORM_FEE_PERCENT=0
